# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript/JSX files
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.tsx text eol=lf

# JSON files
*.json text eol=lf

# Markdown
*.md text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.env* text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
